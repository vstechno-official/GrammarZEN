run = "py .grammarzen/main.py"
entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-23_11"
packages = ["gcc", "openjdk17"]

[deployment]
run = ["sh", "-c", "python main.py"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python src/main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80
